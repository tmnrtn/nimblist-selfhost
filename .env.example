# =============================================================================
# Nimblist self-hosting — environment configuration
# Copy this file to `.env` and fill in at least the REQUIRED values, then:
#   docker compose up -d
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED
# -----------------------------------------------------------------------------

# Database password for the bundled Postgres. Generate a strong one:
#   openssl rand -base64 24
POSTGRES_PASSWORD=

# The public URL your instance is reached on (the address your own TLS proxy
# serves). Used for OAuth redirects and email links. No trailing slash.
#   e.g. https://nimblist.example.com
PUBLIC_BASE_URL=

# -----------------------------------------------------------------------------
# RECOMMENDED
# -----------------------------------------------------------------------------

# The first user who registers with this email is promoted to Admin on startup.
# Leave empty to skip admin promotion (you can do it later in the DB).
ADMIN_EMAIL=

# Signing key for the browser-extension JWT auth. Without it, the web app still
# works fully; only the optional browser extension's token login is disabled.
# Generate (use 32+ bytes):
#   openssl rand -base64 48
JWT_KEY=

# Web Push (VAPID) — enables "notify me when family adds an item".
# Generate a key pair (Node required):
#   npx web-push generate-vapid-keys
# The public key is served to the SPA at runtime via /api/config — no rebuild.
# Leave all three empty to disable push (the notification banner won't appear).
VAPID_SUBJECT=mailto:you@example.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# OPTIONAL — deployment tuning
# -----------------------------------------------------------------------------

# Host port the stack listens on (plain HTTP — front it with your TLS proxy).
# NIMBLIST_HTTP_PORT=8080

# Pin a specific image version instead of tracking :latest.
#   e.g. NIMBLIST_VERSION=1.3.0
# NIMBLIST_VERSION=latest

# Override the bundled Postgres database/user names (password is set above).
# POSTGRES_DB=nimblistdb
# POSTGRES_USER=nimblist

# Extra CORS origins (semicolon-separated). The web app is same-origin so this
# is normally unnecessary; set it only if the browser extension calls your API.
# CORS_ALLOWED_ORIGINS=

# -----------------------------------------------------------------------------
# OPTIONAL — social login (configure only the providers you want)
# -----------------------------------------------------------------------------
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# OPTIONAL — transactional email (Resend, https://resend.com)
# Without this, the app runs but sends no emails (password reset, invites).
# FromAddress format: "Name <noreply@yourdomain.com>"
# -----------------------------------------------------------------------------
# RESEND_API_KEY=
# RESEND_FROM_ADDRESS=Nimblist <noreply@example.com>

# -----------------------------------------------------------------------------
# OPTIONAL — LLM-backed recipe import (URL + image import fallback)
# Leave RECIPESCRAPER_LLM_PROVIDER empty to disable all LLM features.
# Supported providers: openrouter, openai, anthropic, gemini, ollama
# -----------------------------------------------------------------------------
# RECIPESCRAPER_LLM_PROVIDER=openrouter
# RECIPESCRAPER_LLM_MODEL=anthropic/claude-haiku-4-5
# RECIPESCRAPER_LLM_VISION_MODEL=anthropic/claude-haiku-4-5
# OPENROUTER_API_KEY=
# Only when using the ollama provider:
# OLLAMA_BASE_URL=
